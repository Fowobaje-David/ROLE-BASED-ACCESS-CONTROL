# Copy this file to `.env.local` and fill in. `.env.local` is git-ignored.
# These are read by Create React App at build time (must be prefixed REACT_APP_).

# Deployed AdminPanel contract address (paste after you deploy).
REACT_APP_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Sepolia testnet chain id. Leave as-is.
REACT_APP_CHAIN_ID=11155111

# Sepolia RPC URL — used for read-only role detection before a wallet connects.
REACT_APP_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
