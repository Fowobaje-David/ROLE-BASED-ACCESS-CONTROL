# ===========================================================================
# Hardhat / deployment environment — COPY this file to `.env` and fill in.
# NEVER commit your real `.env`. It is git-ignored. Use PLACEHOLDER-only here.
# All addresses/keys below are for the SEPOLIA TESTNET ONLY.
# ===========================================================================

# --- Network + deployer (used by hardhat.config.js, deploy.js, grantTestRoles.js) ---

# RPC endpoint for Sepolia (e.g. Alchemy / Infura / public RPC).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key of the DEPLOYER / OWNER wallet (Sepolia testnet only, no real funds).
# The 0x prefix is optional — the config adds it if missing. Keep this secret, never commit.
PRIVATE_KEY=your_deployer_private_key_here

# Etherscan API key — required for `npx hardhat verify`.
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# --- grantTestRoles.js inputs (filled in AFTER you deploy) ---

# Deployed AdminPanel contract address (paste after running deploy.js).
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Tester wallet addresses YOU create (disposable Sepolia testnet wallets only).
# grantTestRoles.js grants MODERATOR_ROLE to the first and REGULAR_USER_ROLE to the second.
# Only addresses go here — never paste private keys into this project.
TEST_MODERATOR_ADDRESS=0xYourTestModeratorAddress
TEST_USER_ADDRESS=0xYourTestUserAddress
