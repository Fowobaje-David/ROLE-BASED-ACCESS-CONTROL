# ===========================================================================
# AdminPanel API — environment. Copy to `.env` and fill in. `.env` is git-ignored.
# ===========================================================================

# --- Required (reads) ---

# Sepolia RPC endpoint (Alchemy / Infura / public).
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployed AdminPanel contract address.
CONTRACT_ADDRESS=0x18a5883dA6302e13021910235Cb74653b8804505

# Chain id + explorer (defaults suit Sepolia; change only for another network).
CHAIN_ID=11155111
EXPLORER_BASE=https://sepolia.etherscan.io

# HTTP port.
PORT=8080

# --- Optional (writes) ---
# Leave BOTH blank to run a safe READ-ONLY API (write endpoints return 503).
#
# Operator wallet private key that signs write transactions. MUST hold the
# on-chain role for the action (OWNER for admin ops). Sepolia testnet only,
# never a mainnet key. Keep secret — server-side only, never returned by the API.
OPERATOR_PRIVATE_KEY=

# --- API keys (issue keys to other developers) ---

# Secret used to SIGN and VERIFY issued API keys (stateless HMAC — no database).
# Generate one with:  npm run secret
API_KEY_SECRET=

# Secret that authorizes minting new keys via POST /api/v1/keys (x-admin-secret header).
# Generate one with:  npm run secret
ADMIN_SECRET=

# Optional legacy single shared key (full write scope). Prefer issued keys above.
API_KEY=

# Optional: comma-separated key IDs to revoke, e.g. "a1b2c3d4e5f6,9f8e7d6c5b4a".
REVOKED_KEYS=

# --- AI documentation assistant (optional) ---

# Google Gemini API key. Stays SERVER-SIDE — never sent to the browser.
# Leave blank to disable the assistant (endpoint then returns 503).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: comma-separated allowed CORS origins (default "*").
CORS_ORIGINS=*
